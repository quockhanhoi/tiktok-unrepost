{
  "manifest_version": 3,
  "name": "TikTok Repost Ultimate - Quản Lý Repost Chuyên Nghiệp",
  "short_name": "TRU Premium",
  "version": "4.5",
  "description": "TikTok Repost Ultimate v4.5 - Quản lý hồ sơ TikTok: xóa Repost/Unfavorite hàng loạt, hủy FL qua giao diện, chỉnh delay theo giây. Phát triển bởi Nguyễn Văn Kiên.",
  "author": "Nguyễn Văn Kiên",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "TikTok Repost Ultimate",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.tiktok.com/*"],
      "js": ["trap.js", "javascript/webmssdk_5.1.3.js", "untrap.js", "inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["trap.js", "untrap.js", "inject.js", "javascript/webmssdk_5.1.3.js", "admin.jpg"],
      "matches": ["*://*.tiktok.com/*"]
    }
  ]
}